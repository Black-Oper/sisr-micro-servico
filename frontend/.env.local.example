# =========================================================
#  frontend/.env.local.example — config do frontend (VERSIONADO)
#
#  Como usar: copie para `.env.local` (que fica fora do git).
#    cp .env.local.example .env.local
#  Em produção, defina estas variáveis no painel da Vercel.
# =========================================================

# URL pública da API do orchestrator (EXPOSTA AO NAVEGADOR).
# Prefixo NEXT_PUBLIC_ = visível no client; NUNCA coloque segredos aqui.
# Dev local: aponte para o orchestrator em http://localhost:8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# Chave da API — precisa bater com a API_KEY do orchestrator.
# ATENÇÃO: com o prefixo NEXT_PUBLIC_ ela fica VISÍVEL no navegador. Serve para
# barrar acesso não-browser/bots; não é um segredo forte (isso exigiria login).
NEXT_PUBLIC_API_KEY=dev-local-key
