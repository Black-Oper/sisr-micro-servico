# =========================================================
#  .env.example — template de variáveis de ambiente (VERSIONADO)
#
#  Como usar: copie este arquivo para `.env` e ajuste os valores.
#    cp .env.example .env
#  O Docker Compose carrega o `.env` automaticamente. O `.env` real
#  fica FORA do git (ver .gitignore). Nunca commite segredos.
#
#  Os defaults abaixo são para DESENVOLVIMENTO LOCAL. Em produção,
#  troque credenciais por valores fortes e habilite TLS.
# =========================================================

# ---------------- RabbitMQ (fila / transporte de jobs) ----------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_QUEUE=sisr.jobs.queue

# ---------------- Redis (estado / status dos jobs) ----------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_JOB_TTL=86400          # TTL dos jobs em segundos (24h)

# ---------------- MinIO (storage S3 de artefatos) ----------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_INPUT=sisr-inputs
MINIO_BUCKET_OUTPUT=sisr-outputs
MINIO_SECURE=false           # true para TLS (produção)
RETENTION_DAYS=1             # dias até as imagens expirarem no MinIO (limpeza automática)

# ---------------- orchestrator (Java / Spring Boot) ----------------
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=docker
MAX_UPLOAD_SIZE=10MB
CORS_ALLOWED_ORIGINS=http://localhost:3000   # em prod: domínio da Vercel
API_KEY=dev-local-key        # chave da API (cabeçalho X-API-Key). Em prod: use um valor FORTE

# ---------------- worker (Python / PyTorch) ----------------
MODEL_PATH=/app/models/RTDVSR_best_model.pth
MODEL_SCALE=2
DEVICE=cpu                   # cpu | cuda
WORKER_PREFETCH=1
LOG_LEVEL=INFO

# Nota: a config do FRONTEND fica em frontend/.env.local.example
# (NEXT_PUBLIC_API_BASE_URL), pois o front roda na Vercel, não aqui.
